# Copy this file to .env and fill in real values. Never commit .env to version control.

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_db_password

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change_me_base64_encoded_32_byte_secret

# NIBSS webhook HMAC secret — generate with: openssl rand -hex 32
NIBSS_WEBHOOK_SECRET=change_me_strong_nibss_secret

# Optional overrides
SPRING_DATASOURCE_URL=jdbc:postgresql://nexus-db:5432/nexus_bank
SPRING_DATASOURCE_USERNAME=postgres
SPRING_KAFKA_BOOTSTRAP_SERVERS=nexus-kafka:9092
